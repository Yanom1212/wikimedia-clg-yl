@model Models.Media

<dd>
    @Model.Title - @Helper.SharedMedia(Model, "Text")
</dd>
<dd>
    @Helper.YoutubePlayer(Model.YoutubeId)
</dd>
<dd class="description">
    @Model.Description
</dd>
<dt>
    Catégorie
</dt>

<dd>
    @Model.Category
</dd>

<dt>
    Date de publication
</dt>

<dd>
    @Helper.When(Model.PublishDate)
</dd>

<dt>
    Publier par
</dt>

<dd>
    @Helper.AvatarUser(Model.Owner, "UserMediumAvatar")
</dd>